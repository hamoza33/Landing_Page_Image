# Yunwu / OpenAI-compatible API
YUNWU_API_KEY=sk-your-key-here
YUNWU_BASE_URL=https://yunwu.ai

# Optional: Google Vision fallback
GOOGLE_VISION_API_KEY=

# Analyzer backend: yunwu (default) or google_vision
ANALYZER_BACKEND=yunwu

# App
APP_HOST=0.0.0.0
APP_PORT=8000
OUTPUT_DIR=./output
UPLOAD_DIR=./uploads

# Image generation
IMAGE_WIDTH=1024
SECTION_HEIGHT=3072
IMAGE_CONCURRENCY=3

# HTTP timeout for Yunwu API (seconds) — 1024x3072 images can take 60-180s each
HTTP_TIMEOUT=600
