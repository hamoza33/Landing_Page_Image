# =============================================================================
# Yunwu (LLM + image generation)
# =============================================================================
YUNWU_API_KEY=sk-your-key-here
YUNWU_BASE_URL=https://yunwu.ai

# Vision + Arabic copy
YUNWU_CHAT_MODEL=gpt-5.4

# Multi-reference image-edit model used for ALL 8 sections.
# Always uses the user's product photo as reference image #1 and the
# previous section's bottom strip as reference image #2 (when applicable).
YUNWU_IMAGE_EDIT_MODEL=gpt-image-2-all
YUNWU_IMAGE_MODEL=gpt-image-2

# =============================================================================
# Web research (Tavily) — optional, used to enrich the product brief
# =============================================================================
TAVILY_API_KEY=
WEB_RESEARCH_ENABLED=true

# =============================================================================
# Analyzer (reserved for future backends)
# =============================================================================
ANALYZER_BACKEND=yunwu
GOOGLE_VISION_API_KEY=

# =============================================================================
# App / runtime
# =============================================================================
APP_HOST=0.0.0.0
APP_PORT=8000
OUTPUT_DIR=./output
UPLOAD_DIR=./uploads
ASSETS_DIR=./assets

# Public base URL of THIS service. Used to expose the user's uploaded
# product photo and per-section seam strips as URLs that gpt-image-2-all
# can fetch directly via the image: [...] array (matches the n8n flow).
# Must be reachable from Yunwu's servers.
PUBLIC_BASE_URL=https://landing.shopinzo.bond

# Image-edit calls can take 4-8 minutes per section
HTTP_TIMEOUT=600

# =============================================================================
# Image generation
# =============================================================================
# Yunwu gpt-image-2-all supports: 1024x1024, 1536x1024, 1024x1536
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=high
IMAGE_FORMAT=png
IMAGE_CONCURRENCY=3

# =============================================================================
# Seamless visual continuity between sections
# =============================================================================
SEAMLESS_FLOW=true
SEAM_STRIP_HEIGHT=256
SEAM_BLEND_HEIGHT=96

# =============================================================================
# Arabic text overlay (PIL fallback — disabled by default).
# gpt-image-2-all now renders the Arabic text directly on the image; the
# PIL overlay stays available as a fallback if you ever want pixel-perfect
# typography. Flip to true to draw text on top of the model's output.
# =============================================================================
OVERLAY_TEXT_ENABLED=false
FONT_ARABIC_REGULAR=assets/fonts/NotoNaskhArabic-Regular.ttf
FONT_ARABIC_BOLD=assets/fonts/Tajawal-Bold.ttf
OVERLAY_HEADLINE_SIZE=96
OVERLAY_SUBHEAD_SIZE=56
OVERLAY_BODY_SIZE=44
OVERLAY_TEXT_COLOR=#1f2937
OVERLAY_SHADOW_COLOR=#00000099
OVERLAY_MAX_WIDTH_RATIO=0.86
OVERLAY_PADDING_RATIO=0.06
